{
  "name": "wheee",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --cwd packages/client dev",
    "dev:server": "bun run --cwd packages/server dev",
    "build": "bun run --filter '*' build",
    "test": "bun test --cwd packages/server",
    "test:watch": "bun test --cwd packages/server --watch",
    "deploy": "bash deploy/deploy-all.sh",
    "deploy:server": "bash deploy/deploy-all.sh --server",
    "deploy:ru": "bash deploy/deploy-all.sh --ru",
    "deploy:archives": "bash deploy/deploy-all.sh --archives",
    "deploy:env": "bash deploy/deploy-all.sh --env-only"
  }
}
