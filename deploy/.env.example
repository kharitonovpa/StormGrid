PORT=3001
# Yandex Games origins (*.yandex.ru/com/net) are accepted dynamically — no need to list them here
ALLOWED_ORIGINS=https://wheee.io,https://ru.wheee.io
VITE_API_URL=https://api.wheee.io
# RECONNECT_GRACE_MS=30000

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_CALLBACK_URL=https://api.wheee.io/api/auth/callback
CLIENT_ORIGIN=https://wheee.io
COOKIE_DOMAIN=.wheee.io

# Telegram Mini App (optional — leave empty to disable TG auth)
TG_BOT_TOKEN=

# Database (SQLite file path inside container)
DB_PATH=/data/wheee.db
